{
  "name": "account-service",
  "version": "1.0.0",
  "scripts": {
    "start": "node src/server.js",
    "dev": "nodemon src/server.js",
    "test": "jest tests/unit tests/api",
    "test:coverage": "jest tests/unit tests/api --coverage --collectCoverageFrom=src/**/*.js --coveragePathIgnorePatterns=src/server.js --coveragePathIgnorePatterns=src/kafka.js --coveragePathIgnorePatterns=src/Export.service.js --coveragePathIgnorePatterns=src/transaction.service.js --coveragePathIgnorePatterns=src/repositories --coveragePathIgnorePatterns=src/account.repository.js",
    "test:integration": "jest tests/integration"
  },
  "dependencies": {
    "axios": "^1.6.0",
    "cors": "^2.8.6",
    "dotenv": "^16.0.0",
    "express": "^4.19.0",
    "jsonwebtoken": "^9.0.0",
    "kafkajs": "^2.2.4",
    "pg": "^8.20.0",
    "redis": "^4.7.0",
    "test": "^3.3.0",
    "uuid": "^14.0.0"
  },
  "devDependencies": {
    "jest": "^29.7.0",
    "nodemon": "^3.1.14",
    "supertest": "^6.0.0"
  },
  "jest": {
    "moduleNameMapper": {
      "^/shared/(.*)$": "<rootDir>/../../shared/$1",
      "^\\.\\./\\.\\./\\.\\./shared/(.*)$": "<rootDir>/../../shared/$1"
    },
    "testPathIgnorePatterns": [
      "/node_modules/"
    ]
  }
}
