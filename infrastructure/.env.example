# ──────────────────────────────────────────────────────────────────
# Quantum Banking System — environment template (Phase 5.3)
# Copy this file to `infrastructure/.env` and fill in real values.
# `.env` is gitignored. NEVER commit real secrets.
# ──────────────────────────────────────────────────────────────────

# ── Auth (identity-service, account-service, api-gateway) ────────
# IMPORTANT: same JWT_SECRET must be shared by every service that
# verifies access tokens. JWT_REFRESH_SECRET is identity-service only.
JWT_SECRET=change_me_access_secret
JWT_REFRESH_SECRET=change_me_refresh_secret
JWT_EXPIRES=24h
JWT_REFRESH_EXPIRES=7d

# ── Database (CockroachDB, single-node insecure) ─────────────────
DB_HOST=cockroachdb
DB_PORT=26257

# ── CORS / frontends ─────────────────────────────────────────────
CORS_ORIGIN=http://localhost:5173,http://localhost:5174

# ── Kafka (KRaft mode, single broker) ────────────────────────────
KAFKA_BROKERS=kafka:9092

# ── Redis (cache + rate-limit + sliding window) ──────────────────
REDIS_URL=redis://redis:6379
BALANCE_CACHE_TTL=60

# ── Account-service / transfers ──────────────────────────────────
DAILY_TRANSFER_LIMIT_TND=10000

# ── KMS (BB84-derived AES-256-GCM keys) ──────────────────────────
KEY_TTL_SEC=300
KEY_ROUNDS=3
KEY_QUBITS=1024

# ── Quantum service (Qiskit) ─────────────────────────────────────
# QUANTUM_BACKEND: "simulator" (default, free) or "ibm" (real hardware).
# IBM credentials only required when backend=ibm. NEVER commit real ones.
# Get fresh credentials at https://quantum.ibm.com/account
QUANTUM_BACKEND=simulator
QRNG_BUFFER_BYTES=4096
IBM_QUANTUM_TOKEN=
IBM_QUANTUM_CRN=

# ── Phase 5.2 — production HTTPS (Caddy overlay) ─────────────────
# Domain Caddy should obtain a Let's Encrypt cert for. Set to
# `localhost` to use Caddy's internal CA (self-signed, no DNS needed).
CADDY_DOMAIN=localhost
CADDY_EMAIL=admin@example.com
