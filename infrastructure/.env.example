# Quantum-service environment template — copy to .env and fill in real values.
# .env is gitignored; THIS file (with placeholders) is committed.

# QUANTUM_BACKEND: "simulator" (default, recommended) or "ibm" (real hardware).
QUANTUM_BACKEND=simulator

# QRNG buffer size in bytes (refilled lazily from the backend).
QRNG_BUFFER_BYTES=4096

# IBM Quantum credentials — ONLY needed when QUANTUM_BACKEND=ibm.
# Get fresh ones at https://quantum.ibm.com/account ; never commit them.
IBM_QUANTUM_TOKEN=8XnZpeipYuw7dv3axmAdIbTtM8u0K7iQZmUSwk8P8CEv
